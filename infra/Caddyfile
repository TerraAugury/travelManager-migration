:80 {
  route {
    encode gzip
    header {
      X-Content-Type-Options "nosniff"
      X-Frame-Options "DENY"
      Referrer-Policy "strict-origin-when-cross-origin"
      Content-Security-Policy "default-src 'self'; script-src 'self' https://unpkg.com; style-src 'self' 'unsafe-inline' https://unpkg.com; img-src 'self' data: https:; connect-src 'self' https://api.aviationstack.com; font-src 'self' data:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }

    handle_path /api/* {
      reverse_proxy backend:8000
    }

    root * /srv/app
    try_files {path} /index.html
    file_server
  }
}
