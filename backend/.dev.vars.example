# Wrangler local-dev secrets — copy this file to .dev.vars and fill in values.
# .dev.vars is gitignored and is read automatically by `wrangler dev`.
# In production, set each variable with: wrangler secret put <NAME>

# Optional: AviationStack API key for GET /flights/lookup?fn=XX123
# Free tier (100 req/month): https://aviationstack.com/
# Leave blank to disable the lookup feature locally.
AVIATIONSTACK_API_KEY=your_api_key_here

# Optional: AeroDataBox API key (via RapidAPI) for GET /flights/lookup?fn=XX123&provider=aerodatabox
# Free tier: https://rapidapi.com/aedbx-aedbx/api/aerodatabox
# Leave blank to disable AeroDataBox lookup locally.
AERODATABOX_API_KEY=your_rapidapi_key_here
